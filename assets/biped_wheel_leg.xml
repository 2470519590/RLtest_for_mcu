<mujoco model="five_bar_biped_wheel_leg">
  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.001" integrator="Euler" cone="elliptic" impratio="8" iterations="160" tolerance="1e-10"/>

  <visual>
    <quality shadowsize="4096"/>
    <headlight ambient="0.58 0.58 0.58" diffuse="0.72 0.72 0.72" specular="0.03 0.03 0.03"/>
  </visual>

  <default>
    <geom friction="1.0 0.02 0.001" solimp="0.9 0.95 0.001" solref="0.02 1"/>
    <joint damping="0.06" armature="0.008"/>
    <motor ctrllimited="true"/>
    <default class="drive_joint">
      <joint axis="0 1 0" range="-1.35 1.35"/>
      <motor gear="45" ctrlrange="-1 1"/>
    </default>
    <default class="passive_joint">
      <joint axis="0 1 0" range="-2.8 2.8" damping="0.18" stiffness="0.8" springref="0" armature="0.002"/>
    </default>
    <default class="wheel">
      <joint axis="0 1 0" damping="0.02" armature="0.002"/>
      <motor gear="12" ctrlrange="-1 1"/>
    </default>
    <default class="visual_only">
      <geom contype="0" conaffinity="0"/>
    </default>
    <default class="link_collision">
      <geom type="capsule" size="0.008" rgba="0.45 0.62 0.80 0" friction="0.8 0.01 0.001" contype="0" conaffinity="0"/>
    </default>
    <default class="hidden_collision">
      <geom rgba="0 0 0 0" friction="0.8 0.01 0.001" contype="2" conaffinity="0"/>
    </default>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.72 0.78 0.84" rgb2="0.42 0.48 0.56" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.66 0.68 0.70" rgb2="0.60 0.62 0.64" width="512" height="512"/>
    <material name="floor_mat" texture="grid" texrepeat="8 8" reflectance="0.0" specular="0.0" shininess="0.0"/>
    <material name="body_mat" rgba="0.10 0.16 0.22 1"/>
    <material name="upper_mat" rgba="0.70 0.72 0.75 1"/>
    <material name="lower_mat" rgba="0.45 0.62 0.80 1"/>
    <material name="joint_mat" rgba="0.95 0.75 0.22 1"/>
    <material name="carrier_mat" rgba="0.22 0.28 0.34 0.35"/>
    <material name="wheel_mat" rgba="0.02 0.02 0.02 1"/>
    <material name="motor_mat" rgba="0.18 0.18 0.20 1"/>
    <material name="front_mat" rgba="0.95 0.08 0.04 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 4" dir="0 0 -1" diffuse="0.75 0.75 0.75" ambient="0.45 0.45 0.45" specular="0.03 0.03 0.03" castshadow="false"/>
    <light pos="2 -3 3" dir="-0.4 0.6 -1" diffuse="0.28 0.28 0.28" ambient="0.12 0.12 0.12" specular="0.02 0.02 0.02" castshadow="false"/>
    <geom name="floor" type="plane" size="20 20 0.1" material="floor_mat" conaffinity="3"/>
    <body name="base" pos="0 0 0.72">
      <freejoint name="floating_base"/>
      <inertial pos="0 0 0" mass="6.5" diaginertia="0.10 0.18 0.20"/>
      <geom name="base_box" type="box" size="0.18 0.14 0.11" material="body_mat"/>
      <geom name="battery_box" type="box" pos="0 0 0.12" size="0.12 0.09 0.035" material="body_mat"/>
      <geom name="front_marker" type="sphere" pos="0.18 0 0.035" size="0.02" material="front_mat"/>

      <!-- Left five-bar leg. The two top joints are actuated; the two middle
           elbow joints are passive hinges; the lower links meet at the wheel carrier. -->
      <body name="left_front_upper" pos="0.09 0.17 -0.05">
        <joint name="left_front_drive" class="drive_joint"/>
        <geom name="left_front_motor_housing" class="visual_only" type="cylinder" pos="0 -0.018 0" size="0.032 0.012" euler="1.57079632679 0 0" material="motor_mat"/>
        <geom name="left_front_upper_collision" class="link_collision" fromto="0 0 0 0.07 0 -0.20"/>
        <geom name="left_front_upper_link" class="visual_only" type="box" fromto="0 0 0 0.07 0 -0.20" size="0.012 0.006 0.001" material="upper_mat"/>
        <body name="left_front_elbow" pos="0.07 0 -0.20">
          <joint name="left_front_elbow_joint" class="passive_joint"/>
          <geom name="left_front_elbow_collision" class="hidden_collision" type="sphere" size="0.026"/>
          <geom name="left_front_elbow_geom" class="visual_only" type="cylinder" size="0.024 0.014" euler="1.57079632679 0 0" material="joint_mat"/>
          <geom name="left_front_lower_collision" class="link_collision" fromto="0 0 0 -0.16 0 -0.21"/>
          <geom name="left_front_lower_link" class="visual_only" type="box" fromto="0 0 0 -0.16 0 -0.21" size="0.011 0.005 0.001" material="lower_mat"/>
          <body name="left_front_hub" pos="-0.16 0 -0.21">
            <joint name="left_front_hub_joint" class="passive_joint"/>
            <geom name="left_front_hub_collision" class="hidden_collision" type="sphere" size="0.026"/>
            <geom name="left_front_hub_geom" class="visual_only" type="sphere" size="0.023" material="joint_mat"/>
          <body name="left_carrier" pos="0 0 0">
            <site name="left_carrier_front_site" pos="0 0 0" size="0.004"/>
            <site name="left_carrier_site" pos="0 0 0" size="0.004"/>
            <site name="left_carrier_rear_site" pos="0 0 0" size="0.004"/>
            <geom name="left_carrier_collision" class="hidden_collision" type="cylinder" size="0.018 0.055" euler="1.57079632679 0 0"/>
            <geom name="left_carrier_axle_geom" class="visual_only" type="cylinder" size="0.018 0.055" euler="1.57079632679 0 0" material="joint_mat"/>
            <body name="left_wheel" pos="0 0.085 0">
              <joint name="left_wheel_joint" class="wheel"/>
              <geom name="left_wheel_geom" type="cylinder" size="0.085 0.028" euler="1.57079632679 0 0" material="wheel_mat" mass="0.35"/>
            </body>
          </body>
          </body>
        </body>
      </body>
      <body name="left_rear_upper" pos="-0.09 0.17 -0.05">
        <joint name="left_rear_drive" class="drive_joint"/>
        <geom name="left_rear_motor_housing" class="visual_only" type="cylinder" pos="0 -0.018 0" size="0.032 0.012" euler="1.57079632679 0 0" material="motor_mat"/>
        <geom name="left_rear_upper_collision" class="link_collision" fromto="0 0 0 -0.07 0 -0.20"/>
        <geom name="left_rear_upper_link" class="visual_only" type="box" fromto="0 0 0 -0.07 0 -0.20" size="0.012 0.006 0.001" material="upper_mat"/>
        <body name="left_rear_elbow" pos="-0.07 0 -0.20">
          <joint name="left_rear_elbow_joint" class="passive_joint"/>
          <geom name="left_rear_elbow_collision" class="hidden_collision" type="sphere" size="0.026"/>
          <geom name="left_rear_elbow_geom" class="visual_only" type="cylinder" size="0.024 0.014" euler="1.57079632679 0 0" material="joint_mat"/>
          <body name="left_rear_hub" pos="0.16 0 -0.21">
            <site name="left_rear_hub_site" pos="0 0 0" size="0.004"/>
            <geom name="left_rear_hub_collision" class="hidden_collision" type="sphere" size="0.026"/>
            <geom name="left_rear_lower_collision" class="link_collision" fromto="0 0 0 -0.16 0 0.21"/>
            <geom name="left_rear_lower_link" class="visual_only" type="box" fromto="0 0 0 -0.16 0 0.21" size="0.011 0.005 0.001" material="lower_mat"/>
            <geom name="left_rear_hub_marker" class="visual_only" type="sphere" size="0.023" material="joint_mat"/>
          </body>
        </body>
      </body>

      <!-- Right five-bar leg mirrors the left. -->
      <body name="right_front_upper" pos="0.09 -0.17 -0.05">
        <joint name="right_front_drive" class="drive_joint"/>
        <geom name="right_front_motor_housing" class="visual_only" type="cylinder" pos="0 0.018 0" size="0.032 0.012" euler="1.57079632679 0 0" material="motor_mat"/>
        <geom name="right_front_upper_collision" class="link_collision" fromto="0 0 0 0.07 0 -0.20"/>
        <geom name="right_front_upper_link" class="visual_only" type="box" fromto="0 0 0 0.07 0 -0.20" size="0.012 0.006 0.001" material="upper_mat"/>
        <body name="right_front_elbow" pos="0.07 0 -0.20">
          <joint name="right_front_elbow_joint" class="passive_joint"/>
          <geom name="right_front_elbow_collision" class="hidden_collision" type="sphere" size="0.026"/>
          <geom name="right_front_elbow_geom" class="visual_only" type="cylinder" size="0.024 0.014" euler="1.57079632679 0 0" material="joint_mat"/>
          <geom name="right_front_lower_collision" class="link_collision" fromto="0 0 0 -0.16 0 -0.21"/>
          <geom name="right_front_lower_link" class="visual_only" type="box" fromto="0 0 0 -0.16 0 -0.21" size="0.011 0.005 0.001" material="lower_mat"/>
          <body name="right_front_hub" pos="-0.16 0 -0.21">
            <joint name="right_front_hub_joint" class="passive_joint"/>
            <geom name="right_front_hub_collision" class="hidden_collision" type="sphere" size="0.026"/>
            <geom name="right_front_hub_geom" class="visual_only" type="sphere" size="0.023" material="joint_mat"/>
          <body name="right_carrier" pos="0 0 0">
            <site name="right_carrier_front_site" pos="0 0 0" size="0.004"/>
            <site name="right_carrier_site" pos="0 0 0" size="0.004"/>
            <site name="right_carrier_rear_site" pos="0 0 0" size="0.004"/>
            <geom name="right_carrier_collision" class="hidden_collision" type="cylinder" size="0.018 0.055" euler="1.57079632679 0 0"/>
            <geom name="right_carrier_axle_geom" class="visual_only" type="cylinder" size="0.018 0.055" euler="1.57079632679 0 0" material="joint_mat"/>
            <body name="right_wheel" pos="0 -0.085 0">
              <joint name="right_wheel_joint" class="wheel"/>
              <geom name="right_wheel_geom" type="cylinder" size="0.085 0.028" euler="1.57079632679 0 0" material="wheel_mat" mass="0.35"/>
            </body>
          </body>
          </body>
        </body>
      </body>
      <body name="right_rear_upper" pos="-0.09 -0.17 -0.05">
        <joint name="right_rear_drive" class="drive_joint"/>
        <geom name="right_rear_motor_housing" class="visual_only" type="cylinder" pos="0 0.018 0" size="0.032 0.012" euler="1.57079632679 0 0" material="motor_mat"/>
        <geom name="right_rear_upper_collision" class="link_collision" fromto="0 0 0 -0.07 0 -0.20"/>
        <geom name="right_rear_upper_link" class="visual_only" type="box" fromto="0 0 0 -0.07 0 -0.20" size="0.012 0.006 0.001" material="upper_mat"/>
        <body name="right_rear_elbow" pos="-0.07 0 -0.20">
          <joint name="right_rear_elbow_joint" class="passive_joint"/>
          <geom name="right_rear_elbow_collision" class="hidden_collision" type="sphere" size="0.026"/>
          <geom name="right_rear_elbow_geom" class="visual_only" type="cylinder" size="0.024 0.014" euler="1.57079632679 0 0" material="joint_mat"/>
          <body name="right_rear_hub" pos="0.16 0 -0.21">
            <site name="right_rear_hub_site" pos="0 0 0" size="0.004"/>
            <geom name="right_rear_hub_collision" class="hidden_collision" type="sphere" size="0.026"/>
            <geom name="right_rear_lower_collision" class="link_collision" fromto="0 0 0 -0.16 0 0.21"/>
            <geom name="right_rear_lower_link" class="visual_only" type="box" fromto="0 0 0 -0.16 0 0.21" size="0.011 0.005 0.001" material="lower_mat"/>
            <geom name="right_rear_hub_marker" class="visual_only" type="sphere" size="0.023" material="joint_mat"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <equality>
    <connect name="left_lower_loop" site1="left_rear_hub_site" site2="left_carrier_site" solref="0.001 1" solimp="0.995 0.999 0.0001"/>
    <connect name="right_lower_loop" site1="right_rear_hub_site" site2="right_carrier_site" solref="0.001 1" solimp="0.995 0.999 0.0001"/>
  </equality>

  <actuator>
    <motor name="left_front_motor" joint="left_front_drive" class="drive_joint"/>
    <motor name="left_rear_motor" joint="left_rear_drive" class="drive_joint"/>
    <motor name="left_wheel_motor" joint="left_wheel_joint" class="wheel"/>
    <motor name="right_front_motor" joint="right_front_drive" class="drive_joint"/>
    <motor name="right_rear_motor" joint="right_rear_drive" class="drive_joint"/>
    <motor name="right_wheel_motor" joint="right_wheel_joint" class="wheel"/>
  </actuator>
</mujoco>
